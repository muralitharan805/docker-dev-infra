# ==============================================================================
# PostgreSQL pgvector Database Configuration Example
# Copy this file to '.env' and customize it for your local environment.
# ==============================================================================

# Database Access Credentials
# Ensure you use a strong, unique password in your active .env file
POSTGRES_DB=vectordb
POSTGRES_USER=vector_admin
POSTGRES_PASSWORD=replace_with_a_secure_random_password

# Host Port Mapping
# If port 5432 is already in use by a local PostgreSQL installation,
# change this to another port (e.g., 5433, 5434) to avoid port binding conflicts.
POSTGRES_PORT=5432

# Healthcheck parameters
# Defines how long to wait and how many retries before declaring service failures.
HEALTHCHECK_INTERVAL=10s
HEALTHCHECK_TIMEOUT=5s
HEALTHCHECK_RETRIES=5
HEALTHCHECK_START_PERIOD=5s
